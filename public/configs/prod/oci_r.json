      "title": "שאלון טורדנות כפייתית (OCI-R)",
      "description": "הערכת תסמיני OCD במהלך השבוע האחרון (OCD, Obsessive-Compulsive, OCI-R)",
      "keywords": [
        "OCD",
        "obsessive",
        "compulsive",
        "OCI",
        "OCI-R",
        "checking",
        "hoarding",
        "washing"
      ],
      "defaultOptionSetId": "distress_5",
