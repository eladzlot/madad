{
  "id": "stss",
  "version": "1.0.0",
  "questionnaires": [
    {
      "id": "stss",
      "title": "שאלון סטרס טראומטי משני (STSS)",
      "description": "שאלון דיווח עצמי בן 17 פריטים המודד סטרס טראומטי משני בקרב אנשי מקצוע העובדים עם מטופלים שחוו טראומה, בשבעת הימים האחרונים; מפיק תת-סולמות של חדירה, הימנעות ועוררות.",
      "keywords": [
        "trauma",
        "secondary traumatic stress",
        "STSS",
        "compassion fatigue",
        "טראומה משנית",
        "סטרס טראומטי משני",
        "שחיקת חמלה",
        "מטפלים"
      ],
      "meta": {
        "domains": [
          "trauma"
        ],
        "type": "severity",
        "populations": [
          "adult"
        ],
        "tags": [
          "secondary trauma",
          "clinicians"
        ]
      },
      "defaultOptionSetId": "frequency_5",
      "optionSets": {
        "frequency_5": [
          {
            "label": "לעולם לא",
            "value": 1
          },
          {
            "label": "לעיתים רחוקות",
            "value": 2
          },
          {
            "label": "מדי פעם",
            "value": 3
          },
          {
            "label": "לעיתים קרובות",
            "value": 4
          },
          {
            "label": "לעיתים קרובות מאוד",
            "value": 5
          }
        ]
      },
      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "להלן רשימת היגדים שנאמרו על-ידי אנשים שעבודתם עם מטופלים שחוו טראומה השפיעה עליהם. קרא/י כל היגד וסמן/י באיזו תדירות היה נכון עבורך במהלך שבעת הימים האחרונים. \"מטופל\" מתייחס לכל אדם שעימו את/ה נמצא/ת בקשר של עזרה או טיפול."
        },
        {
          "id": "1",
          "type": "select",
          "text": "חשתי קהות רגשית."
        },
        {
          "id": "2",
          "type": "select",
          "text": "ליבי החל להלום כאשר חשבתי על עבודתי עם מטופלים."
        },
        {
          "id": "3",
          "type": "select",
          "text": "נדמה היה לי כאילו אני חווה מחדש את הטראומה שחוו המטופלים שלי."
        },
        {
          "id": "4",
          "type": "select",
          "text": "התקשיתי לישון."
        },
        {
          "id": "5",
          "type": "select",
          "text": "חשתי מיואש/ת לגבי העתיד."
        },
        {
          "id": "6",
          "type": "select",
          "text": "תזכורות לעבודתי עם מטופלים עוררו בי מצוקה."
        },
        {
          "id": "7",
          "type": "select",
          "text": "היה לי מעט עניין להיות בחברת אנשים אחרים."
        },
        {
          "id": "8",
          "type": "select",
          "text": "נבהלתי בקלות והייתי דרוך/ה."
        },
        {
          "id": "9",
          "type": "select",
          "text": "הייתי פעיל/ה פחות מהרגיל."
        },
        {
          "id": "10",
          "type": "select",
          "text": "מצאתי את עצמי חושב/ת על עבודתי עם מטופלים גם כאשר לא התכוונתי לכך."
        },
        {
          "id": "11",
          "type": "select",
          "text": "התקשיתי להתרכז."
        },
        {
          "id": "12",
          "type": "select",
          "text": "נמנעתי מאנשים, ממקומות או מדברים שהזכירו לי את עבודתי עם מטופלים."
        },
        {
          "id": "13",
          "type": "select",
          "text": "חלמתי חלומות מטרידים על עבודתי עם מטופלים."
        },
        {
          "id": "14",
          "type": "select",
          "text": "רציתי להימנע מעבודה עם חלק מהמטופלים."
        },
        {
          "id": "15",
          "type": "select",
          "text": "התעצבנתי בקלות."
        },
        {
          "id": "16",
          "type": "select",
          "text": "ציפיתי שיקרה משהו רע."
        },
        {
          "id": "17",
          "type": "select",
          "text": "הבחנתי בפערים בזיכרוני לגבי מפגשים עם מטופלים."
        }
      ],
      "scoring": {
        "method": "subscales",
        "subscales": {
          "intrusion": [
            "2",
            "3",
            "6",
            "10",
            "13"
          ],
          "avoidance": [
            "1",
            "5",
            "7",
            "9",
            "12",
            "14",
            "17"
          ],
          "arousal": [
            "4",
            "8",
            "11",
            "15",
            "16"
          ]
        }
      },
      "subscaleLabels": {
        "intrusion": "חדירה (Intrusion)",
        "avoidance": "הימנעות (Avoidance)",
        "arousal": "עוררות (Arousal)"
      },
      "interpretations": {
        "target": "total",
        "type": "severity",
        "ranges": [
          {
            "min": 17,
            "max": 27,
            "label": "טראומה משנית מזערית או ללא"
          },
          {
            "min": 28,
            "max": 37,
            "label": "טראומה משנית קלה"
          },
          {
            "min": 38,
            "max": 43,
            "label": "טראומה משנית בינונית"
          },
          {
            "min": 44,
            "max": 48,
            "label": "טראומה משנית גבוהה"
          },
          {
            "min": 49,
            "max": 85,
            "label": "טראומה משנית חמורה"
          }
        ],
        "cutoffs": [
          {
            "value": 38,
            "label": "סף לנוכחות STS"
          }
        ]
      },
      "psychometrics": {
        "reliability": 0.93,
        "sd": 10.76,
        "source": "Bride et al. 2004"
      },
      "alerts": [
        {
          "id": "clinical_cutoff",
          "condition": "score.stss >= 38",
          "message": "מעל סף לטראומה משנית",
          "severity": "warning"
        }
      ]
    }
  ]
