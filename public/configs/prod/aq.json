        "subscaleFormulas": {
          "social_skill": "sum(if(item.1 <= 1, 1, 0), if(item.11 <= 1, 1, 0), if(item.13 >= 2, 1, 0), if(item.15 <= 1, 1, 0), if(item.22 >= 2, 1, 0), if(item.36 <= 1, 1, 0), if(item.44 <= 1, 1, 0), if(item.45 >= 2, 1, 0), if(item.47 <= 1, 1, 0), if(item.48 <= 1, 1, 0))",
          "attention_switching": "sum(if(item.2 >= 2, 1, 0), if(item.4 >= 2, 1, 0), if(item.10 <= 1, 1, 0), if(item.16 >= 2, 1, 0), if(item.25 <= 1, 1, 0), if(item.32 <= 1, 1, 0), if(item.34 <= 1, 1, 0), if(item.37 <= 1, 1, 0), if(item.43 >= 2, 1, 0), if(item.46 >= 2, 1, 0))",
          "attention_to_detail": "sum(if(item.5 >= 2, 1, 0), if(item.6 >= 2, 1, 0), if(item.9 >= 2, 1, 0), if(item.12 >= 2, 1, 0), if(item.19 >= 2, 1, 0), if(item.23 >= 2, 1, 0), if(item.28 <= 1, 1, 0), if(item.29 <= 1, 1, 0), if(item.30 <= 1, 1, 0), if(item.49 <= 1, 1, 0))",
          "communication": "sum(if(item.7 >= 2, 1, 0), if(item.17 <= 1, 1, 0), if(item.18 >= 2, 1, 0), if(item.26 >= 2, 1, 0), if(item.27 <= 1, 1, 0), if(item.31 <= 1, 1, 0), if(item.33 >= 2, 1, 0), if(item.35 >= 2, 1, 0), if(item.38 <= 1, 1, 0), if(item.39 >= 2, 1, 0))",
          "imagination": "sum(if(item.3 <= 1, 1, 0), if(item.8 <= 1, 1, 0), if(item.14 <= 1, 1, 0), if(item.20 >= 2, 1, 0), if(item.21 >= 2, 1, 0), if(item.24 <= 1, 1, 0), if(item.40 <= 1, 1, 0), if(item.41 >= 2, 1, 0), if(item.42 >= 2, 1, 0), if(item.50 <= 1, 1, 0))"
        }
      },
      "subscaleLabels": {
        "social_skill": "מיומנויות חברתיות (Social Skill)",
        "attention_switching": "הטיית/שינוי קשב (Attention Switching)",
        "attention_to_detail": "קשב לפרטים (Attention to Detail)",
        "communication": "תקשורת (Communication)",
        "imagination": "דמיון (Imagination)"
      },
      "interpretations": {
        "target": "total",
        "type": "screening",
        "ranges": [
          {
            "min": 0,
            "max": 21,
            "label": "מתחת לסף הסינון"
          },
          {
            "min": 22,
            "max": 50,
            "label": "מעל סף הסינון — מומלצת הערכה מקיפה"
          }
        ],
        "cutoffs": [
          {
            "value": 22,
            "label": "סף סינון ישראלי"
          }
        ]
      },
      "alerts": [
        {
          "id": "above_cutoff",
          "condition": "score.aq >= 22",
          "message": "מעל סף סינון AQ",
          "severity": "warning"
        }
      ]
    }
  ]
}
