{
  "id": "cape15",
  "version": "1.0.0",
  "questionnaires": [
    {
      "id": "cape15",
      "meta": {
        "domains": [
          "psychosis"
        ],
        "type": "screener",
        "populations": [
          "adult"
        ]
      },
      "title": "שאלון חוויות פסיכוטיות עכשוויות (CAPE-P15)",
      "description": "שאלון דיווח עצמי בן 15 פריטים לאיתור חוויות דמויות-פסיכוזה במהלך שלושת החודשים האחרונים (הגרסה העכשווית של CAPE-P15).",
      "keywords": [
        "psychosis",
        "PLE",
        "CAPE",
        "screening",
        "פסיכוזה",
        "חוויות פסיכוטיות",
        "סינון"
      ],
      "defaultOptionSetId": "frequency_4",
      "optionSets": {
        "frequency_4": [
          {
            "label": "לעולם לא",
            "value": 0
          },
          {
            "label": "לעיתים",
            "value": 1
          },
          {
            "label": "לעיתים קרובות",
            "value": 2
          },
          {
            "label": "כמעט כל הזמן",
            "value": 3
          }
        ]
      },
      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "השאלות הבאות עוסקות במחשבות, ברגשות ובחוויות שיש לעיתים לאנשים. לגבי כל שאלה, סמן/י באיזו תדירות חווית זאת במהלך שלושת החודשים האחרונים."
        },
        {
          "id": "1",
          "type": "select",
          "text": "האם הרגשת שאנשים רומזים לגביך או אומרים דברים בעלי משמעות כפולה?"
        },
        {
          "id": "2",
          "type": "select",
          "text": "האם הרגשת שאנשים מסוימים הם לא מה שהם נראים?"
        },
        {
          "id": "3",
          "type": "select",
          "text": "האם הרגשת נרדף/ת בדרך כלשהי?"
        },
        {
          "id": "4",
          "type": "select",
          "text": "האם הרגשת שישנה קנוניה נגדך?"
        },
        {
          "id": "5",
          "type": "select",
          "text": "האם הרגשת שאנשים מסתכלים עליך בצורה מוזרה בגלל המראה שלך?"
        },
        {
          "id": "6",
          "type": "select",
          "text": "האם הרגשת שמכשירים אלקטרוניים, כמו לדוגמה מחשב, יכולים להשפיע על הדרך שבה את/ה חושב/ת?"
        },
        {
          "id": "7",
          "type": "select",
          "text": "האם הרגשת שהמחשבות בראש שלך נלקחות ממך?"
        },
        {
          "id": "8",
          "type": "select",
          "text": "האם הרגשת שהמחשבות בראש שלך הן של מישהו אחר?"
        },
        {
          "id": "9",
          "type": "select",
          "text": "האם קרה שהמחשבות שלך היו מוחשיות עד כדי כך שדאגת שאחרים יכולים לשמוע אותן?"
        },
        {
          "id": "10",
          "type": "select",
          "text": "האם שמעת את המחשבות שלך חוזרות אליך כמו הד?"
        },
        {
          "id": "11",
          "type": "select",
          "text": "האם הרגשת שאת/ה תחת השפעתו של כוח או שליטה של מישהו אחר?"
        },
        {
          "id": "12",
          "type": "select",
          "text": "האם הרגשת כאילו שכפיל החליף מישהו מבני משפחתך, חבריך או מכריך?"
        },
        {
          "id": "13",
          "type": "select",
          "text": "האם שמעת קולות כשהיית לבד?"
        },
        {
          "id": "14",
          "type": "select",
          "text": "האם שמעת קולות משוחחים ביניהם כשהיית לבד?"
        },
        {
          "id": "15",
          "type": "select",
          "text": "האם ראית חפצים, אנשים או בעלי חיים, שאף אחד אחר אינו רואה?"
        }
      ],
      "scoring": {
        "method": "subscales",
        "subscales": {
          "persecutory": [
            "1",
            "2",
            "3",
            "4",
            "5"
          ],
          "bizarre": [
            "6",
            "7",
            "8",
            "9",
            "10",
            "11",
            "12"
          ],
          "perceptual": [
            "13",
            "14",
            "15"
          ]
        }
      },
      "subscaleLabels": {
        "persecutory": "מחשבות רדיפה (Persecutory Ideation)",
        "bizarre": "חוויות ביזאריות (Bizarre Experiences)",
        "perceptual": "עיוותים תפיסתיים (Perceptual Abnormalities)"
      },
      "psychometrics": {
        "reliability": 0.84,
        "sd": 4.51,
        "source": "Capra et al. 2017"
      },
      "alerts": [
        {
          "id": "hallucinations",
          "condition": "item.13 >= 2 || item.14 >= 2 || item.15 >= 2",
          "message": "דיווח על חוויות הזייתיות",
          "severity": "critical"
        }
      ]
    }
  ]
}
