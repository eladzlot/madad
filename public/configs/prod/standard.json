{
  "id": "standard",
  "version": "1.0.0",
  "questionnaires": [
    {
      "id": "test_q",
      "title": "שאלון בדיקה",
      "defaultOptionSetId": "agree_4",
      "optionSets": {
        "yesno": [
          { "label": "כן", "value": 1 },
          { "label": "לא", "value": 0 }
        ],
        "agree_4": [
          { "label": "כלל לא", "value": 0 },
          { "label": "קצת", "value": 1 },
          { "label": "במידה רבה", "value": 2 },
          { "label": "לגמרי", "value": 3 }
        ]
      },
      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "ברוכים הבאים לשאלון הבדיקה.\nשאלון זה מכיל שאלות בינאריות ושאלות ליקרט."
        },
        {
          "id": "b1",
          "type": "binary",
          "text": "האם ישנת טוב הלילה?",
          "optionSetId": "yesno"
        },
        {
          "id": "b2",
          "type": "binary",
          "text": "האם הרגשת רגוע היום?",
          "optionSetId": "yesno"
        },
        {
          "id": "l1",
          "type": "likert",
          "text": "הרגשתי ממוקד ופרודוקטיבי במהלך היום"
        },
        {
          "id": "l2",
          "type": "likert",
          "text": "הרגשתי קשר ותמיכה מאנשים סביבי"
        }
      ],
      "scoring": { "method": "sum" },
      "alerts": []
    },
    {
      "id": "phq9",
      "title": "PHQ-9",
      "defaultOptionSetId": "frequency_4",
      "optionSets": {
        "frequency_4": [
          { "label": "כלל לא", "value": 0 },
          { "label": "מספר ימים", "value": 1 },
          { "label": "יותר ממחצית הזמן", "value": 2 },
          { "label": "כמעט כל יום", "value": 3 }
        ]
      },
      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "במהלך השבועיים האחרונים, באיזו תדירות היית מוטרד מכל אחת מן הבעיות הבאות?"
        },
        { "id": "1", "type": "likert", "text": "עניין או הנאה מועטים מעשיית דברים" },
        { "id": "2", "type": "likert", "text": "תחושת דכדוך, דיכאון, או חוסר תקווה" },
        { "id": "3", "type": "likert", "text": "קשיים בהירדמות או בשינה רציפה, או עודף שינה" },
        { "id": "4", "type": "likert", "text": "תחושה של עייפות או אנרגיה מועטה" },
        { "id": "5", "type": "likert", "text": "תיאבון מועט או אכילת יתר" },
        { "id": "6", "type": "likert", "text": "מרגיש רע לגבי עצמך — מרגיש שאתה כישלון או שאכזבת את עצמך או את משפחתך" },
        { "id": "7", "type": "likert", "text": "קושי להתרכז בדברים, כמו קריאה בעיתון או צפייה בטלוויזיה" },
        { "id": "8", "type": "likert", "text": "היית מדבר או נע באיטיות עד כי אחרים הבחינו בכך? או להיפך — היית חסר שקט ומנוחה" },
        { "id": "9", "type": "likert", "text": "מחשבות שהיה עדיף לו היית מת, או מחשבות על פגיעה בעצמך בדרך כלשהי" }
      ],
      "scoring": { "method": "sum", "maxPerItem": 3 },
      "alerts": [
        {
          "id": "suicidality",
          "condition": "item.9 >= 1",
          "message": "פריט 9 — המטופל דיווח על מחשבות אובדניות או פגיעה עצמית",
          "severity": "critical"
        }
      ]
    }
  ],
  "batteries": [
    {
      "id": "standard_intake",
      "title": "שאלון בדיקה",
      "sequence": [{ "questionnaireId": "test_q" }]
    },
    {
      "id": "phq9_intake",
      "title": "הערכה ראשונית — דיכאון",
      "sequence": [{ "questionnaireId": "phq9" }]
    }
  ]
}
