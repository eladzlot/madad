      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "מספר מהשאלות הבאות מתייחסות להתקפי פאניקה ולהתקפים מצומצמים.\n\nהתקף פאניקה מוגדר כבהלה פתאומית של פחד או אי-נחת המלווה בלפחות 4 מהתסמינים הבאים, המגיעים לשיאם תוך 10 דקות. אפיזודות הכוללות פחות מ-4 תסמינים נקראות התקפים מצומצמי סימפטומים."
        },
        {
          "id": "symptoms",
          "type": "multiselect",
          "text": "סמן/י את התסמינים שחווית במהלך התקפי הפאניקה שלך:",
          "options": [
            {
              "label": "דופק לב מהיר או חזק"
            },
            {
              "label": "הזעה"
            },
            {
              "label": "רעידות"
            },
            {
              "label": "קוצר נשימה"
            },
            {
              "label": "תחושת מחנק"
            },
            {
              "label": "כאב בחזה או אי-נחת"
            },
            {
              "label": "בחילה"
            },
            {
              "label": "סחרחורת או חולשה"
            },
            {
              "label": "תחושת אי-מציאות או ניתוק"
            },
            {
              "label": "פחד לאבד שליטה או להשתגע"
            },
            {
              "label": "פחד למות"
            },
            {
              "label": "צמרמורות או הסמקות"
            },
            {
              "label": "תחושת שיתוק או דקירות"
            }
          ]
        },
        {
          "id": "1",
          "type": "select",
          "text": "כמה התקפי פאניקה והתקפים מצומצמים היו לך בשבוע האחרון?",
          "options": [
            {
              "label": "לא היו התקפי פאניקה או התקפים מצומצמים",
              "value": 0
            },
            {
              "label": "קל: לא היו התקפים מלאים, לא יותר מהתקף מצומצם אחד ביום",
              "value": 1
            },
            {
              "label": "מתון: 1–2 התקפים מלאים ו/או מספר התקפים מצומצמים ביום",
              "value": 2
            },
            {
              "label": "חמור: יותר מ-2 התקפים מלאים, בממוצע לא יותר מאחד ביום",
              "value": 3
            },
            {
              "label": "קיצוני: התקפים מלאים בתדירות של יותר מפעם ביום, יותר ימים כן מאשר לא",
              "value": 4
            }
          ]
        },
        {
          "id": "2",
          "type": "select",
          "text": "אם היו לך התקפי פאניקה במהלך השבוע האחרון, כמה מעיקים היו בזמן התרחשותם? (אם היה יותר מהתקף אחד — דרג/י ממוצע. אם היו רק התקפים מצומצמים — התייחס/י אליהם).",
          "optionSetId": "distress_5"
        },
        {
          "id": "3",
          "type": "select",
          "text": "במהלך השבוע האחרון, כמה היית מודאג/ת או חרד/ה בנוגע למתי יתרחש ההתקף הבא, או בנוגע לפחדים הקשורים להתקפים (למשל, שיש לך בעיה רפואית, שתאבד/י שליטה, או שייגרם לך מבוכה חברתית)?",
          "optionSetId": "worry_5"
        },
        {
          "id": "4",
          "type": "select",
          "text": "במהלך השבוע האחרון, האם נמנעת מ- או פחדת ממצבים ומקומות (כגון תחבורה ציבורית, קניון, קהל, גשרים, להיות לבד) בגלל פחד לקבל התקף פאניקה?",
          "optionSetId": "avoidance_5"
        },
        {
          "id": "5",
          "type": "select",
          "text": "במהלך השבוע האחרון, האם נמנעת מ- או פחדת מפעילויות (כמו מאמץ גופני, קשרים מיניים, מקלחת חמה, שתיית קפה, צפייה בסרט מתח) מפני שגרמו לתחושות גופניות דומות לאלו של התקף פאניקה?",
          "optionSetId": "avoidance_5"
        },
        {
          "id": "6",
          "type": "select",
          "text": "במהלך השבוע האחרון, כמה הפריעו תסמיני הפאניקה בכללותם ליכולתך לעבוד או לבצע את חובותיך בבית?",
          "optionSetId": "impairment_5"
        },
        {
          "id": "7",
          "type": "select",
          "text": "במהלך השבוע האחרון, כמה הפריעו תסמיני הפאניקה בכללותם לחיים החברתיים שלך?",
          "optionSetId": "impairment_5"
        }
      ],
      "scoring": {
        "method": "sum"
      },
      "interpretations": {
        "target": "total",
        "type": "screening",
        "ranges": [
          {
            "min": 0,
            "max": 8,
            "label": "מתחת לסף קליני"
          },
          {
            "min": 9,
            "max": 28,
            "label": "מעל סף סינון לפאניקה"
          }
        ],
        "cutoffs": [
