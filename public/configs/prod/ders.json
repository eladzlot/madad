        },
        {
          "id": "21",
          "type": "select",
          "text": "כשאני נסער, אני מרגיש בושה כלפי עצמי שאני מרגיש כך"
        },
        {
          "id": "22",
          "type": "select",
          "text": "כשאני נסער, אני יודע שאני יכול למצוא דרך להרגיש טוב בסופו של דבר",
          "reverse": true
        },
        {
          "id": "23",
          "type": "select",
          "text": "כשאני נסער, אני מרגיש שאני חלש"
        },
        {
          "id": "24",
          "type": "select",
          "text": "כשאני נסער, אני מרגיש שאני עדיין יכול לשלוט על התנהגותי",
          "reverse": true
        },
        {
          "id": "25",
          "type": "select",
          "text": "כשאני נסער, אני מרגיש אשמה על שאני מרגיש כך"
        },
        {
          "id": "26",
          "type": "select",
          "text": "כשאני נסער, אני מתקשה להתרכז"
        },
        {
          "id": "27",
          "type": "select",
          "text": "כשאני נסער, אני מתקשה לשלוט בהתנהגותי"
        },
        {
          "id": "28",
          "type": "select",
          "text": "כשאני נסער, אני מאמין שאין משהו שביכולתי לעשות על מנת להרגיש טוב יותר"
        },
        {
          "id": "29",
          "type": "select",
          "text": "כשאני נסער, אני נהיה עצבני על עצמי שאני מרגיש כך"
        },
        {
          "id": "30",
          "type": "select",
          "text": "כשאני נסער, אני מתחיל להרגיש רע מאוד לגבי עצמי"
        },
        {
          "id": "31",
          "type": "select",
          "text": "כשאני נסער, אני מאמין שלשקוע בזה, זה כל מה שאני יכול לעשות"
        },
        {
          "id": "32",
          "type": "select",
          "text": "כשאני נסער, אני מאבד שליטה בהתנהגותי"
        },
        {
          "id": "33",
          "type": "select",
          "text": "כשאני נסער, אני מתקשה לחשוב על משהו אחר"
        },
        {
          "id": "34",
          "type": "select",
          "text": "כשאני נסער, אני לוקח זמן להבין מה אני באמת מרגיש",
          "reverse": true
        },
        {
          "id": "35",
          "type": "select",
          "text": "כשאני נסער, לוקח לי הרבה זמן להרגיש טוב יותר"
        },
        {
          "id": "36",
          "type": "select",
          "text": "כשאני נסער, הרגשות שלי מסעירים ומזעזעים"
        }
