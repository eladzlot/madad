      "items": [
        {
          "id": "intro",
          "type": "instructions",
          "text": "אנא ענה/י עד כמה המשפטים הבאים מתארים אותך בצורה הטובה ביותר, על פי השכיחות שבה את/ה חווה את התחושות או ההתנהגויות המתוארות."
        },
        {
          "id": "1",
          "type": "select",
          "text": "אני מודע לרגשות שלי",
          "reverse": true
        },
        {
          "id": "2",
          "type": "select",
          "text": "אני שם לב לרגשותיי",
          "reverse": true
        },
        {
          "id": "3",
          "type": "select",
          "text": "אני חווה את רגשותיי כמסעירים ובלתי נשלטים"
        },
        {
          "id": "4",
          "type": "select",
          "text": "איני יודע כיצד אני מרגיש"
        },
        {
          "id": "5",
          "type": "select",
          "text": "אני מתקשה למצוא היגיון ברגשותיי"
        },
        {
          "id": "6",
          "type": "select",
          "text": "אני קשוב לרגשותיי",
          "reverse": true
        },
        {
          "id": "7",
          "type": "select",
          "text": "אני יודע בדיוק כיצד אני מרגיש",
          "reverse": true
        },
        {
          "id": "8",
          "type": "select",
          "text": "אכפת לי מה אני מרגיש",
          "reverse": true
        },
        {
          "id": "9",
          "type": "select",
          "text": "אני מבולבל ממה שאני מרגיש"
        },
        {
          "id": "10",
          "type": "select",
          "text": "כשאני נסער, אני מכיר ברגשותיי",
          "reverse": true
        },
        {
          "id": "11",
          "type": "select",
          "text": "כשאני נסער, אני כועס על עצמי שאני מרגיש כך"
        },
        {
          "id": "12",
          "type": "select",
          "text": "כשאני נסער, אני נהיה נבוך שאני מרגיש כך"
        },
        {
          "id": "13",
          "type": "select",
          "text": "כשאני נסער, אני מתקשה לסיים דברים"
        },
        {
          "id": "14",
          "type": "select",
          "text": "כשאני נסער, אני מאבד שליטה"
        },
        {
          "id": "15",
          "type": "select",
          "text": "כשאני נסער, אני מאמין שאשאר במצב זה כך לאורך זמן"
        },
        {
          "id": "16",
          "type": "select",
          "text": "כשאני נסער, אני מאמין שבסוף ארגיש מאוד מדוכא"
        },
        {
          "id": "17",
          "type": "select",
          "text": "כשאני נסער, אני מאמין שרגשותיי תקפים ובעלי משמעות",
          "reverse": true
        },
        {
          "id": "18",
          "type": "select",
          "text": "כשאני נסער, אני מתקשה להתרכז בדברים נוספים"
        },
        {
          "id": "19",
          "type": "select",
          "text": "כשאני נסער, אני מרגיש שאני מאבד שליטה"
        },
        {
          "id": "20",
          "type": "select",
          "text": "כשאני נסער, אני בכל זאת מצליח לסיים דברים",
