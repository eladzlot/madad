{
  "name": "madad",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host --mode development",
    "build:validator": "node scripts/build-validator.mjs",
    "build": "npm run build:validator && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "lint": "eslint src tests composer/src",
    "lint:fix": "eslint src tests composer/src --fix",
    "validate:configs": "node scripts/validate-configs.mjs",
    "size": "node scripts/check-size.mjs",
    "ci": "npm run lint && npm test && npm run validate:configs && npm run build && npm run size && npm run e2e"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "bidi-js": "^1.0.3",
    "lit": "^3.3.2",
    "pdfmake": "^0.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "axe-core": "^4.11.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.3",
    "prettier": "^3.8.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
