{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "QuestionnaireSet",
  "type": "object",
  "required": [
    "id",
    "version",
    "questionnaires"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "$ref": "#/$defs/id"
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "questionnaires": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/questionnaire"
      }
    },
    "batteries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/battery"
      }
    },
    "dependencies": {
      "type": "array",
      "description": "Config files that must be loaded alongside this one. Paths relative to the app root, without leading slash. The composer will automatically include these when generating patient URLs.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_]*$"
    },
    "meta": {
      "type": "object",
      "required": [
        "domains"
      ],
      "additionalProperties": false,
      "description": "Catalog metadata used by the composer for browsing, filtering, and the curated default view. Never shown to patients and never affects scoring. 'type' is required on questionnaires, optional on batteries (a battery mixes types). 'populations' defaults to adult when absent.",
      "properties": {
        "domains": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "depression",
              "anxiety",
              "ocd",
              "trauma",
              "psychosis",
              "sleep",
              "anger",
              "social",
              "attachment",
              "emotion_regulation",
              "functioning",
              "alliance",
              "neurodevelopmental",
              "intake",
              "general"
            ]
          }
        },
        "type": {
          "enum": [
            "screener",
            "severity",
            "process",
            "worksheet",
            "other"
          ],
          "description": "Primary clinical use. screener = case-finding; severity = symptom severity; process = mechanism/process measure (incl. alliance, attachment); worksheet = intervention material (logs, exercises); other = administrative (e.g. demographics)."
        },
        "populations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "adult",
              "adolescent",
              "child",
              "parent"
            ]
          }
        },
        "tags": {
          "type": "array",
          "uniqueItems": true,
          "description": "Free-form intervention/protocol tags (e.g. CBT, exposure). Not schema-validated beyond shape — keep spelling consistent.",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "featured": {
          "type": "boolean",
          "description": "Shown in the composer's curated default view. Reserve for common workhorse instruments."
        },
        "durationMinutes": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Estimated completion time. Overrides the catalog's computed estimate."
        }
      }
    },
    "optionList": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "required": [
          "label",
          "value"
        ],
        "additionalProperties": false,
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "value": {
            "type": "number"
          }
        }
      }
    },
    "questionnaire": {
      "type": "object",
      "required": [
        "id",
        "title",
        "items"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optionSets": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_]*$"
          },
          "additionalProperties": {
            "$ref": "#/$defs/optionList"
          }
        },
        "defaultOptionSetId": {
          "$ref": "#/$defs/id"
        },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/item"
          }
        },
        "scoring": {
          "$ref": "#/$defs/scoring"
        },
        "subscaleLabels": {
          "type": "object",
          "description": "Optional display labels for subscale IDs. Keys must match subscale IDs in scoring.subscales. Values are free-form strings shown in the PDF.",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "interpretations": {
          "$ref": "#/$defs/interpretations"
        },
        "psychometrics": {
          "$ref": "#/$defs/psychometrics"
        },
        "meta": {
          "allOf": [
            {
              "$ref": "#/$defs/meta"
            },
            {
              "type": "object",
              "required": [
                "type"
              ]
            }
          ]
        },
        "alerts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/alert"
          }
        }
      }
    },
    "item": {
      "oneOf": [
        {
          "$ref": "#/$defs/selectItem"
        },
        {
          "$ref": "#/$defs/binaryItem"
        },
        {
          "$ref": "#/$defs/instructionsItem"
        },
        {
          "$ref": "#/$defs/textItem"
        },
        {
          "$ref": "#/$defs/sliderItem"
        },
        {
          "$ref": "#/$defs/multiselectItem"
        },
        {
          "$ref": "#/$defs/ifNode"
        },
        {
          "$ref": "#/$defs/randomizeNode"
        }
      ]
    },
    "selectItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "select"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "$ref": "#/$defs/optionList"
        },
        "optionSetId": {
          "$ref": "#/$defs/id"
        },
        "reverse": {
          "type": "boolean"
        },
        "weight": {
          "type": "number"
        },
        "required": {
          "type": "boolean"
        }
      },
      "not": {
        "required": [
          "options",
          "optionSetId"
        ]
      }
    },
    "binaryItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "binary"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "$ref": "#/$defs/optionList"
        },
        "optionSetId": {
          "type": "string"
        },
        "reverse": {
          "type": "boolean"
        },
        "weight": {
          "type": "number"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "instructionsItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "instructions"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "textItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "text"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "inputType": {
          "enum": [
            "line",
            "multiline",
            "number",
            "email"
          ],
          "default": "line"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "pattern": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "sliderItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text",
        "min",
        "max"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "slider"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "step": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "labels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "min": {
              "type": "string",
              "minLength": 1
            },
            "max": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "reverse": {
          "type": "boolean"
        },
        "weight": {
          "type": "number"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "multiselectItem": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text",
        "options"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "multiselect"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "label"
            ],
            "additionalProperties": false,
            "properties": {
              "label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "ifNode": {
      "type": "object",
      "required": [
        "id",
        "type",
        "condition",
        "then",
        "else"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "if"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "then": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        },
        "else": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "randomizeNode": {
      "type": "object",
      "required": [
        "id",
        "type",
        "ids"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "type": {
          "const": "randomize"
        },
        "ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/item"
          }
        }
      }
    },
    "scoring": {
      "type": "object",
      "required": [
        "method"
      ],
      "additionalProperties": false,
      "properties": {
        "method": {
          "enum": [
            "none",
            "sum",
            "average",
            "subscales",
            "custom"
          ]
        },
        "subscaleMethod": {
          "enum": [
            "sum",
            "mean"
          ]
        },
        "totalMethod": {
          "enum": [
            "sum_of_subscales",
            "sum_of_items"
          ]
        },
        "subscales": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_]*$"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          }
        },
        "customFormula": {
          "type": "string",
          "minLength": 1
        },
        "subscaleFormulas": {
          "type": "object",
          "description": "Subscale scores computed by DSL formula instead of an item list. Each key is a subscale ID, each value a DSL expression evaluated with the item answers in scope. Use when a subscale is not a plain sum of item values (e.g. binary rescoring).",
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_]*$"
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Item IDs to exclude from sum/average total. Excluded items still appear in the PDF but do not contribute to the score."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "method": {
                "const": "subscales"
              }
            },
            "required": [
              "method"
            ]
          },
          "then": {
            "required": [
              "subscales"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "method": {
                "const": "custom"
              }
            },
            "required": [
              "method"
            ]
          },
          "then": {
            "required": [
              "customFormula"
            ]
          }
        }
      ]
    },
    "interpretations": {
      "type": "object",
      "required": [
        "ranges"
      ],
      "additionalProperties": false,
      "properties": {
        "target": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["severity", "screening"],
          "description": "What the ranges ladder represents. 'severity' ranges render as background bands in trajectory charts; 'screening' documents a dichotomous below/above-threshold ladder (no bands). Optional — absent means no chart overlay from ranges."
        },
        "ranges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "min",
              "max",
              "label"
            ],
            "additionalProperties": false,
            "properties": {
              "min": {
                "type": "number"
              },
              "max": {
                "type": "number"
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "cutoffs": {
          "type": "array",
          "minItems": 1,
          "description": "Explicit clinical thresholds, each rendered as a solid horizontal line in trajectory charts. Values are literal scores — never derived from range boundaries.",
          "items": {
            "type": "object",
            "required": [
              "value"
            ],
            "additionalProperties": false,
            "properties": {
              "value": {
                "type": "number"
              },
              "label": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "psychometrics": {
      "type": "object",
      "required": [
        "reliability",
        "sd",
        "source"
      ],
      "additionalProperties": false,
      "description": "Total-score psychometrics for Reliable Change Index computation (AGGREGATE_SPEC §5.3). Optional — absent means no RCI line renders.",
      "properties": {
        "reliability": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "sd": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "source": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "alert": {
      "type": "object",
      "required": [
        "id",
        "condition",
        "message",
        "severity"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 30,
          "description": "Short badge label shown in the PDF report. Keep under 30 characters."
        },
        "severity": {
          "type": "string",
          "enum": [
            "warning",
            "critical"
          ],
          "description": "Badge type. critical = red pill (safety risk). warning = amber pill (clinical attention)."
        }
      }
    },
    "battery": {
      "type": "object",
      "required": [
        "id",
        "title",
        "sequence"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/batteryNode"
          }
        },
        "meta": {
          "$ref": "#/$defs/meta"
        }
      }
    },
    "batteryNode": {
      "oneOf": [
        {
          "$ref": "#/$defs/questionnaireRef"
        },
        {
          "$ref": "#/$defs/batteryIfNode"
        },
        {
          "$ref": "#/$defs/batteryRandomizeNode"
        }
      ]
    },
    "questionnaireRef": {
      "type": "object",
      "required": [
        "questionnaireId"
      ],
      "additionalProperties": false,
      "not": {
        "required": [
          "type"
        ]
      },
      "properties": {
        "questionnaireId": {
          "$ref": "#/$defs/id"
        },
        "instanceId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "batteryIfNode": {
      "type": "object",
      "required": [
        "type",
        "condition",
        "then",
        "else"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "if"
        },
        "condition": {
          "type": "string",
          "minLength": 1
        },
        "then": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/batteryNode"
          }
        },
        "else": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/batteryNode"
          }
        }
      }
    },
    "batteryRandomizeNode": {
      "type": "object",
      "required": [
        "type",
        "ids"
      ],
      "additionalProperties": false,
      "properties": {
        "type": {
          "const": "randomize"
        },
        "ids": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/batteryNode"
          }
        }
      }
    }
  }
}